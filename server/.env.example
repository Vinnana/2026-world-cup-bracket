# Copy to .env and fill in, then run:  node --env-file=.env index.js

# Optional: enable automatic result fetching from football-data.org.
# Get a free API token at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Optional overrides (sensible defaults shown):
# FOOTBALL_DATA_COMPETITION=WC   # competition code for the World Cup
# FETCH_INTERVAL_MIN=15          # how often the scheduler polls (minutes)
# PORT=3001
# JWT_SECRET=change-me-in-production
